# ═══════════════════════════════════════════════════
# OrbiTail — 환경 변수 설정
# ═══════════════════════════════════════════════════

# ── Django ──
SECRET_KEY=your-secret-key-change-this-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80

# ── HTTPS (Let's Encrypt) ──
# 도메인을 설정하면 HTTPS 자동 활성화, 비워두면 HTTP 모드
DOMAIN=
# 인증서 만료 알림용 이메일 (선택)
CERTBOT_EMAIL=

# ── Docker nginx 포트 바인딩 ──
# 단독 서버(직접 80/443 노출):
#   HOST_BIND_ADDR=0.0.0.0  HOST_HTTP_PORT=80  HOST_HTTPS_PORT=443
# 호스트 nginx 뒤에 둘 때(reverse proxy, 다른 서비스와 공존):
#   HOST_BIND_ADDR=127.0.0.1  HOST_HTTP_PORT=8088  HOST_HTTPS_PORT=8443
HOST_BIND_ADDR=0.0.0.0
HOST_HTTP_PORT=80
HOST_HTTPS_PORT=443

# ── Database ──
POSTGRES_DB=orbitail
POSTGRES_USER=orbitail
POSTGRES_PASSWORD=orbitail
DB_HOST=db
DB_PORT=5432

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── JWT ──
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Frontend ──
# VITE_API_URL은 더 이상 사용 안 함 — axios가 상대경로 /api로 호출
# (개발: vite proxy, 프로덕션: nginx proxy)
FRONTEND_URL=http://localhost:5173

# ── Sponsor Button ──
# true로 설정하면 우측 하단 후원 버튼 표시, false면 숨김
VITE_SHOW_SPONSOR=true

# ── Email (SMTP) ──
# 개발 환경에서는 콘솔 백엔드 사용 (터미널에 이메일 출력)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# 프로덕션 예시 (SendGrid):
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG.xxxxx
# DEFAULT_FROM_EMAIL=noreply@your-domain.com

# 프로덕션 예시 (AWS SES):
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=AKIA...
# EMAIL_HOST_PASSWORD=...
# DEFAULT_FROM_EMAIL=noreply@your-domain.com
